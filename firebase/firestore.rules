rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════
    // Schema
    //
    // /users/{userId}
    //   id, name, email, phone, role, createdAt
    //
    // /bookings/{bookingId}
    //   id, bookingCode, customerId (UID), name, phone, email,
    //   pickup, dropoff, date, time, bags,
    //   price, status, assignedKeeper?, createdAt
    //
    // /trackingEvents/{eventId}
    //   bookingId, status, timestamp, updatedBy
    // ═══════════════════════════════════════════════════════

    // ── Helpers ─────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.token.email == 'luis@azulclarito.mx'
      );
    }

    function isKeeper() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'keeper';
    }

    function isAdminOrKeeper() {
      return isAdmin() || isKeeper();
    }

    function isValidRole(role) {
      return role in ['admin', 'keeper', 'customer'];
    }

    function isValidUser(data) {
      return data.id    is string && data.id.size()    > 0 &&
             data.name  is string && data.name.size()  > 0 &&
             data.email is string && data.email.size() > 0 &&
             data.phone is string &&
             isValidRole(data.role);
    }

    // ── Default deny ────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }

    // ── /users/{userId} ─────────────────────────────────────

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      allow create: if isAuthenticated() &&
        isValidUser(request.resource.data) && (
          (isOwner(userId) && request.resource.data.role == 'customer') ||
          isAdmin()
        );

      allow update: if isAuthenticated() &&
        isValidUser(request.resource.data) && (
          (isOwner(userId) && request.resource.data.role == resource.data.role) ||
          isAdmin()
        );

      allow delete: if isAdmin();
    }

    // ── /bookings/{bookingId} ───────────────────────────────
    //
    // READ strategy:
    //   get  (single doc by ID) → public: anyone with the doc ID or
    //        tracking URL can see the status. Acceptable for a luggage
    //        tracking service — knowing the booking ID already implies
    //        the user received the link.
    //   list (query)            → authenticated only. The client query
    //        is responsible for filtering (customerId / assignedKeeper).
    //        resource.data is NOT available during list, so we trust
    //        the authenticated client to send the correct query.

    match /bookings/{bookingId} {
      // Public GET: anyone with the booking ID (tracking link) can read
      allow get: if true;

      // LIST queries:
      //   - Authenticated users can query freely (dashboard, admin, keeper)
      //   - Unauthenticated users can only do limit-1 queries (tracking by bookingCode)
      allow list: if isAuthenticated() || request.query.limit <= 1;

      // Create: any authenticated user
      allow create: if isAuthenticated();

      // Update: admin full access; keeper updates only their assigned booking;
      // customer can update their own booking (e.g. cancel)
      allow update: if isAdmin() ||
        (isKeeper() && resource.data.assignedKeeper == request.auth.uid) ||
        (isAuthenticated() && resource.data.customerId == request.auth.uid);

      allow delete: if isAdmin();
    }

    // ── /trackingEvents/{eventId} ───────────────────────────
    //
    // Public READ: anyone can read tracking events (they need the
    // bookingId, which is effectively the access token).

    match /trackingEvents/{eventId} {
      allow read: if true;

      // Only keepers and admins can log tracking events
      allow create: if isAdminOrKeeper() &&
        request.resource.data.updatedBy == request.auth.uid;

      allow update, delete: if isAdmin();
    }

  }
}
